{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/login",
      "dest": "public/login.html"
    },
    {
      "src": "/admin",
      "dest": "public/admin.html"
    },
    {
      "src": "/bookings",
      "dest": "public/bookings.html"
    },
    {
      "src": "/whats-new",
      "dest": "public/whats-new.html"
    },
    {
      "src": "/onboarding/(.*)",
      "dest": "public/onboarding.html"
    },
    {
      "src": "/(.*\\.(?:png|jpg|jpeg|svg|ico|css|js))",
      "dest": "public/$1"
    },
    {
      "src": "^/$",
      "dest": "public/index.html"
    }
  ]
}
